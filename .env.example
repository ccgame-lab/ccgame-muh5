APP_NAME="MUH5"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# Database — app
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ccgame_muh5
DB_USERNAME=root
DB_PASSWORD=

# Game DB servers (examples — override locally)
GAME_DB_CHARSET=utf8mb4
GAME_DB_COLLATION=utf8mb4_unicode_ci

GAME_S1_DB_HOST=127.0.0.1
GAME_S1_DB_PORT=3306
GAME_S1_DB_DATABASE=actor_s1
GAME_S1_DB_USERNAME=root
GAME_S1_DB_PASSWORD=

GAME_S2_DB_HOST=127.0.0.1
GAME_S2_DB_PORT=3306
GAME_S2_DB_DATABASE=actor_s2
GAME_S2_DB_USERNAME=root
GAME_S2_DB_PASSWORD=

GAME_S3_DB_HOST=127.0.0.1
GAME_S3_DB_PORT=3306
GAME_S3_DB_DATABASE=actor_s3
GAME_S3_DB_USERNAME=root
GAME_S3_DB_PASSWORD=

GAME_S4_DB_HOST=127.0.0.1
GAME_S4_DB_PORT=3306
GAME_S4_DB_DATABASE=actor_s4
GAME_S4_DB_USERNAME=root
GAME_S4_DB_PASSWORD=

GAME_S5_DB_HOST=127.0.0.1
GAME_S5_DB_PORT=3306
GAME_S5_DB_DATABASE=actor_s5
GAME_S5_DB_USERNAME=root
GAME_S5_DB_PASSWORD=

GAME_S99_DB_HOST=127.0.0.1
GAME_S99_DB_PORT=3306
GAME_S99_DB_DATABASE=actor_s99
GAME_S99_DB_USERNAME=root
GAME_S99_DB_PASSWORD=

# Session / Cache
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=database

# Redis (optional — used by legacy for TopDonate)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Portal API
PORTAL_URL=http://localhost:3001
PORTAL_API_URL=http://localhost:3001/api
PORTAL_GAME_CODE=muh5
PORTAL_GAME_SECRET=change-me-game-secret
PORTAL_API_SECRET=change-me-api-secret
PORTAL_EXCHANGE_RATE=1000
PORTAL_MAX_EXCHANGE=10000
GAME_CODE=muh5

# GreenJade OAuth
GREENJADE_BASE_URL=http://localhost:3000
GREENJADE_CLIENT_ID=change-me-client-id
GREENJADE_CLIENT_SECRET=change-me-client-secret
GREENJADE_REDIRECT_URI=${APP_URL}/auth/greenjade/callback
GREENJADE_ID_BASE_URL=${GREENJADE_BASE_URL}
GREENJADE_ID_CLIENT_ID=${GREENJADE_CLIENT_ID}
GREENJADE_ID_CLIENT_SECRET=${GREENJADE_CLIENT_SECRET}
GREENJADE_ID_REDIRECT_URI=${GREENJADE_REDIRECT_URI}

# Economy
EXCHANGE_RATE=1000
MAX_DIAMOND_PER_DAY=5000
WPOINT_CHECKIN_AMOUNT=5
WPOINT_STREAK_BONUS=2

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
